# ===========================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; this template is committed.
# ===========================================================

# --- Firebase Admin SDK service account ---
# From: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# The private key is a multi-line PEM. Keep the literal "\n" sequences inside
# the quotes — lib/firebase-admin.ts converts them to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"

# --- Session signing key (HS256) ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_32_byte_random_hex

# --- Seed endpoint protection ---
# Generate with: openssl rand -hex 24
# Unset / leave blank in production to disable the /api/seed endpoint.
SEED_TOKEN=replace_me_with_random_token
